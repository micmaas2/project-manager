#!/usr/bin/env bash
# Pre-commit hook for project_manager
# Checks: branch protection, sensitive file detection

set -euo pipefail

# TTY guard: only emit color codes when writing to a terminal
if [[ -t 1 ]]; then
  RED='\033[0;31m'
  YELLOW='\033[1;33m'
  NC='\033[0m'
else
  RED=''
  YELLOW=''
  NC=''
fi

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")

# 1. Block direct commits to main or develop
if [[ "$BRANCH" == "main" || "$BRANCH" == "develop" ]]; then
  printf "%b[pre-commit] ERROR: Direct commits to '%s' are not allowed.%b\n" "$RED" "$BRANCH" "$NC"
  printf "  Create a feature branch: git checkout -b feature/your-description\n"
  exit 1
fi

# 2. Detect sensitive files using basename + regex match
# Targets: .env files (all variants), key material, named secret blobs, SSH private keys
# Intentionally does NOT match source code files containing words like "token" or "credential"
SENSITIVE_PATTERN='(^|/)\.env(\.|$)|(^|/)\.env$|\.pem$|\.key$|\.p12$|\.pfx$|\.ppk$|^id_(rsa|dsa|ed25519|ecdsa)(\.|$)|_secret\.(json|yaml|yml)$|^credentials\.json$|^service-account.*\.json$'

STAGED=$(git diff --cached --name-only)

if [[ -n "$STAGED" ]]; then
  while IFS= read -r file; do
    basename_file=$(basename "$file")
    if echo "$file" | grep -qE "$SENSITIVE_PATTERN" || echo "$basename_file" | grep -qE "$SENSITIVE_PATTERN"; then
      printf "%b[pre-commit] ERROR: Staged file looks sensitive: %s%b\n" "$RED" "$file" "$NC"
      printf "  Remove it from staging: git reset HEAD \"%s\"\n" "$file"
      printf "  If this file is safe to commit, check .gitignore and secret patterns in hooks/pre-commit.\n"
      exit 1
    fi
  done <<< "$STAGED"
fi

# 2b. Scan staged artefacts/ for credential patterns
CRED_PATTERNS=(
  '[0-9]{10}:[A-Za-z0-9_-]{35}'
  'password[[:space:]]*[:=][[:space:]]*[A-Za-z0-9!@#$%^&*]{8,}'
)
STAGED_ARTEFACTS=$(echo "$STAGED" | grep '^artefacts/' || true)
if [[ -n "$STAGED_ARTEFACTS" ]]; then
  for pattern in "${CRED_PATTERNS[@]}"; do
    MATCH=$(git diff --cached -- 'artefacts/*' 2>/dev/null | grep '^\+' | grep -v '^\+\+\+' | grep -v '<redact' | grep -E "$pattern" || true)
    if [[ -n "$MATCH" ]]; then
      printf "%b[pre-commit] ERROR: Credential pattern detected in staged artefacts. Redact and retry.%b\n" "$RED" "$NC"
      exit 1
    fi
  done
fi

# 3. Agent YAML policy-schema consistency check (M-1 guard)
# Every .claude/agents/*.yaml must have all required policy fields.
REQUIRED_POLICY_FIELDS=("allowed_tools" "max_tokens_per_run" "require_human_approval" "audit_logging" "external_calls_allowed")
AGENT_DIR=".claude/agents"

if [[ -d "$AGENT_DIR" ]]; then
  YAML_FAIL=0
  for yaml_file in "$AGENT_DIR"/*.yaml; do
    [[ -f "$yaml_file" ]] || continue
    for field in "${REQUIRED_POLICY_FIELDS[@]}"; do
      if ! grep -q "^  ${field}:" "$yaml_file"; then
        printf "%b[pre-commit] ERROR: Agent YAML missing policy field '%s': %s%b\n" "$RED" "$field" "$yaml_file" "$NC"
        YAML_FAIL=1
      fi
    done
  done
  if [[ $YAML_FAIL -ne 0 ]]; then
    printf "  Fix: add missing fields to the policy: block in the agent YAML.\n"
    exit 1
  fi
fi

# 3b. Agent YAML semantic policy check — require_human_approval must be true when Write/Edit/Bash in allowed_tools
if [[ -d "$AGENT_DIR" ]] && python3 -c "import yaml" &>/dev/null; then
  python3 - "$AGENT_DIR"/*.yaml <<'PYEOF'
import sys, yaml

WRITE_TOOLS = {"Write", "Edit", "Bash"}
fail = 0
for yaml_file in sys.argv[1:]:
    try:
        with open(yaml_file) as f:
            data = yaml.safe_load(f)
        policy = data.get("policy", {})
        tools = set(policy.get("allowed_tools", []))
        rha = policy.get("require_human_approval")
        if tools & WRITE_TOOLS and rha is False:
            print(f"[pre-commit] ERROR: {yaml_file}: require_human_approval must be true when Write/Edit/Bash in allowed_tools")
            fail = 1
    except Exception:
        # Fail-open: hook errors must never block legitimate writes — log and pass through
        pass
sys.exit(fail)
PYEOF
fi

printf "%b[pre-commit] All checks passed.%b\n" "$YELLOW" "$NC"
exit 0
