{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tasks/queue.schema.json",
  "title": "Task Queue",
  "description": "Schema for tasks/queue.json — validated by ProjectManager before any agent reads a task",
  "type": "object",
  "required": ["tasks"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "tasks": {
      "type": "array",
      "items": { "$ref": "#/$defs/task" }
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "required": ["id", "title", "project", "assigned_to", "status", "artefact_path", "created", "updated", "mvp_template"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^task[_-][a-z0-9_-]+$",
          "description": "Unique task identifier, e.g. task-001 or task_001"
        },
        "title": {
          "type": "string",
          "minLength": 5,
          "maxLength": 200
        },
        "project": {
          "type": "string",
          "enum": ["project_manager", "ccas", "pi-homelab", "pensieve", "genealogie", "performance_HPT", "project1", "other"],
          "description": "Short project name matching docs/project-registry.md"
        },
        "target_project_path": {
          "type": "string",
          "description": "Absolute path to target project root, e.g. /opt/claude/CCAS"
        },
        "epic_id": {
          "type": "string",
          "pattern": "^EPIC-[0-9]+$",
          "description": "Optional epic reference, e.g. EPIC-001"
        },
        "story_id": {
          "type": "string",
          "pattern": "^S-[0-9]+-[0-9]+$",
          "description": "Optional story reference, e.g. S-001-5"
        },
        "assigned_to": {
          "type": ["string", "null"],
          "enum": ["manager", "builder", "reviewer", "tester", "doc-updater", "self-improver", null]
        },
        "status": {
          "type": "string",
          "enum": ["pending", "in_progress", "paused", "review", "test", "done", "failed"]
        },
        "artefact_path": {
          "type": "string",
          "pattern": "^artefacts/[a-zA-Z0-9_-]+/$",
          "description": "Must stay within artefacts/ to prevent path traversal"
        },
        "created": {
          "type": "string",
          "format": "date"
        },
        "updated": {
          "type": "string",
          "format": "date"
        },
        "token_estimate": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "resume_from": {
          "type": ["string", "null"],
          "enum": ["builder", "reviewer", "tester", "doc-updater", "self-improver", null],
          "description": "Agent step to resume from after a rate-limit pause"
        },
        "notes": {
          "type": "array",
          "items": { "type": "string", "maxLength": 500 },
          "maxItems": 10,
          "description": "Reviewer/Tester findings passed back to Builder. Array keeps each note bounded."
        },
        "mvp_template": {
          "type": "object",
          "required": ["doel", "niet_in_scope", "acceptatiecriteria", "security_arch_impact", "tests_required", "definition_of_done", "rollback_plan", "incident_owner", "privacy_dpia", "cost_estimate"],
          "additionalProperties": false,
          "properties": {
            "doel": {
              "type": "string",
              "minLength": 10,
              "maxLength": 300,
              "description": "Single-sentence goal for this task"
            },
            "niet_in_scope": {
              "type": "array",
              "items": { "type": "string", "maxLength": 200 },
              "minItems": 1,
              "description": "Explicit exclusions to prevent scope creep"
            },
            "acceptatiecriteria": {
              "type": "array",
              "items": { "type": "string", "maxLength": 300 },
              "minItems": 3,
              "maxItems": 5,
              "description": "Measurable acceptance criteria (3–5 items)"
            },
            "security_arch_impact": {
              "type": "string",
              "maxLength": 500
            },
            "tests_required": {
              "type": "string",
              "maxLength": 500,
              "description": "Test types required: unit/integration/regression/shellcheck/etc."
            },
            "definition_of_done": {
              "type": "array",
              "items": { "type": "string", "maxLength": 200 },
              "minItems": 1
            },
            "rollback_plan": {
              "type": "string",
              "maxLength": 500
            },
            "incident_owner": {
              "type": "string",
              "maxLength": 100
            },
            "privacy_dpia": {
              "type": "string",
              "maxLength": 200,
              "description": "DPIA required? yes/no + note"
            },
            "cost_estimate": {
              "type": "string",
              "maxLength": 100,
              "description": "Estimated cost, e.g. EUR 0 or EUR 2.50"
            }
          }
        }
      }
    }
  }
}
